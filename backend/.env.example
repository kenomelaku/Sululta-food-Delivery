# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/sululta_eats?schema=public"

# JWT Configuration
JWT_SECRET="your_jwt_access_secret_key_here"
REFRESH_TOKEN_SECRET="your_jwt_refresh_secret_key_here"

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Firebase (FCM) Configuration
FIREBASE_SERVICE_ACCOUNT_JSON="{}"

# Payment Keys (Placeholders)
TELEBIRR_API_KEY="your_telebirr_key"
CBE_BIRR_API_KEY="your_cbe_key"